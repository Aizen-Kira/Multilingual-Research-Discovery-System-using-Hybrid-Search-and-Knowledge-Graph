# PolyResearch frontend environment template.
# Copy this file to Frontend/.env for local development.

# Supabase browser-safe public values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-supabase-anon-key

# Must match Backend PUBLIC_API_KEY for protected public API calls.
# This is not a true secret once shipped to browsers; use backend rate limits too.
VITE_PUBLIC_API_KEY=generate-a-64-character-random-hex-public-api-key
