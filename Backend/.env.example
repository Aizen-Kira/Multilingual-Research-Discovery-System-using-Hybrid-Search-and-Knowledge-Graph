# PolyResearch backend environment template.
# Copy this file to Backend/.env for local development.
# Never commit real secrets or generated docker compose config output.

# App
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
APP_LOG_DIR=./logs
VERSION=3.0.0
ENABLE_API_DOCS=true
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API access
# Required for /api/research/*, /api/chat, and paper search endpoints.
# Generate with: openssl rand -hex 32
PUBLIC_API_KEY=generate-a-64-character-random-hex-public-api-key
PUBLIC_API_RATE_LIMIT_PER_MINUTE=6
REQUIRE_PUBLIC_API_KEY=true
ALLOW_QUERY_STRING_API_KEY=false
MIN_API_KEY_LENGTH=32

# Required for /api/cleanup and /api/training-data/*
ADMIN_API_KEY=generate-a-different-64-character-random-admin-api-key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50
CACHE_TTL=3600
REDIS_SEMANTIC_CACHE_THRESHOLD=0.90

# LLM providers. At least one hosted provider is recommended.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
HF_MODEL_REPO=
IEEE_API_KEY=

# Research pipeline
LLM_ANALYSIS_LIMIT=15
MAX_PAPERS_PER_SEARCH=30
MAX_PAPER_AGE_YEARS=10
MIN_ABSTRACT_WORDS=30
RELATIONSHIP_SIMILARITY_THRESHOLD=0.5
RELATIONSHIP_MAX_PER_PAPER=5

# LLM concurrency and pacing
GEMINI_CONCURRENCY=3
GEMINI_INTER_BATCH_SLEEP=4.0
GROQ_CONCURRENCY=2
GROQ_INTER_BATCH_SLEEP=12.0
OPENROUTER_CONCURRENCY=2

# Embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_DEVICE=cpu
SENTENCE_TRANSFORMERS_HOME=/app/data/st_cache
TRANSFORMERS_CACHE=/app/data/hf_cache

# Cleanup and training data
AUTO_CLEANUP_ENABLED=true
CLEANUP_DAYS_OLD=30
MAX_PAPERS_LIMIT=8000
CLEANUP_SCHEDULE_HOUR=3
TRAINING_DATA_DIR=/app/training_data
MIN_QUALITY_FOR_TRAINING=0.4
TRAINING_READY_THRESHOLD=300
