# Root Docker Compose environment.
# Backend runtime secrets are loaded from Backend/.env.
# Frontend Vite values are build-time variables and must be available when
# running `docker compose build frontend` or `docker compose up --build`.

FRONTEND_PORT=8080
BACKEND_MEMORY_LIMIT=4g
BACKEND_CPUS=4.0

APP_ENV=production
ENABLE_API_DOCS=false
REQUIRE_PUBLIC_API_KEY=true
ALLOW_QUERY_STRING_API_KEY=false
MIN_API_KEY_LENGTH=32

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-supabase-anon-key
VITE_PUBLIC_API_KEY=generate-a-64-character-random-hex-public-api-key
